+// ---------------------------------------------------------------------------
+// simplify forwarding (see the `simplify` field on `FFI_ScalarUDF`)
+//
+// `Expr`s cannot cross the C ABI as Rust values, so they travel as
+// datafusion-proto bytes. Resolving a deserialized `Expr` that references
+// built-in scalar functions (e.g. `sin`, `power`) needs a `FunctionRegistry`
+// populated with those functions, on *both* sides of the boundary; both the
+// provider (this wrapper) and the consumer (`ForeignScalarUDF::simplify`) build
+// one from datafusion's default functions.
+// ---------------------------------------------------------------------------
+
+/// A minimal [`FunctionRegistry`] holding datafusion's default scalar
+/// functions, used only to resolve function names while deserializing `Expr`s
+/// that cross the FFI boundary.
+struct DefaultFunctionRegistry {
+    udfs: std::collections::HashMap<String, Arc<ScalarUDF>>,
+}
+
+impl DefaultFunctionRegistry {
+    fn new() -> Self {
+        let udfs = datafusion_functions::all_default_functions()
+            .into_iter()
+            .map(|f| (f.name().to_string(), f))
+            .collect();
+        Self { udfs }
+    }
+}
+
+impl FunctionRegistry for DefaultFunctionRegistry {
+    fn udfs(&self) -> HashSet<String> {
+        self.udfs.keys().cloned().collect()
+    }
+    fn udafs(&self) -> HashSet<String> {
+        HashSet::new()
+    }
+    fn udwfs(&self) -> HashSet<String> {
+        HashSet::new()
+    }
+    fn udf(&self, name: &str) -> Result<Arc<ScalarUDF>> {
+        self.udfs
+            .get(name)
+            .cloned()
+            .ok_or_else(|| DataFusionError::Plan(format!("Function '{name}' not found")))
+    }
+    fn udaf(&self, name: &str) -> Result<Arc<AggregateUDF>> {
+        Err(DataFusionError::Plan(format!(
+            "Aggregate '{name}' not available across the FFI simplify boundary"
+        )))
+    }
+    fn udwf(&self, name: &str) -> Result<Arc<WindowUDF>> {
+        Err(DataFusionError::Plan(format!(
+            "Window function '{name}' not available across the FFI simplify boundary"
+        )))
+    }
+    fn expr_planners(&self) -> Vec<Arc<dyn datafusion_expr::planner::ExprPlanner>> {
+        Vec::new()
+    }
+}
+
+fn default_registry() -> &'static DefaultFunctionRegistry {
+    static REGISTRY: OnceLock<DefaultFunctionRegistry> = OnceLock::new();
+    REGISTRY.get_or_init(DefaultFunctionRegistry::new)
+}
+
+/// Encode a list of `Expr`s as length-prefixed datafusion-proto blobs:
+/// `count:u32` then, per expr, `len:u32` + bytes.
+pub(crate) fn encode_exprs(exprs: &[Expr]) -> Result<Vec<u8>> {
+    let mut out = Vec::new();
+    out.extend_from_slice(&(exprs.len() as u32).to_le_bytes());
+    for expr in exprs {
+        let bytes = expr.to_bytes()?;
+        out.extend_from_slice(&(bytes.len() as u32).to_le_bytes());
+        out.extend_from_slice(&bytes);
+    }
+    Ok(out)
+}
+
+fn read_u32(buf: &[u8], pos: &mut usize) -> Result<u32> {
+    let end = *pos + 4;
+    let slice = buf
+        .get(*pos..end)
+        .ok_or_else(|| DataFusionError::Internal("truncated FFI expr buffer".into()))?;
+    *pos = end;
+    Ok(u32::from_le_bytes(slice.try_into().unwrap()))
+}
+
+/// Inverse of [`encode_exprs`].
+pub(crate) fn decode_exprs(
+    buf: &[u8],
+    registry: &dyn FunctionRegistry,
+) -> Result<Vec<Expr>> {
+    let mut pos = 0usize;
+    let count = read_u32(buf, &mut pos)? as usize;
+    let mut exprs = Vec::with_capacity(count);
+    for _ in 0..count {
+        let len = read_u32(buf, &mut pos)? as usize;
+        let end = pos + len;
+        let slice = buf
+            .get(pos..end)
+            .ok_or_else(|| DataFusionError::Internal("truncated FFI expr buffer".into()))?;
+        exprs.push(Expr::from_bytes_with_registry(slice, registry)?);
+        pos = end;
+    }
+    Ok(exprs)
+}
+
+/// Encode an [`ExprSimplifyResult`]: tag byte `1` + the simplified expr's
+/// bytes, or tag byte `0` for `Original` (the consumer keeps its own args).
+fn encode_simplify_result(result: &ExprSimplifyResult) -> Result<Vec<u8>> {
+    match result {
+        ExprSimplifyResult::Simplified(expr) => {
+            let mut out = vec![1u8];
+            out.extend_from_slice(&expr.to_bytes()?);
+            Ok(out)
+        }
+        ExprSimplifyResult::Original(_) => Ok(vec![0u8]),
+    }
+}
+
+unsafe extern "C" fn simplify_fn_wrapper(
+    udf: &FFI_ScalarUDF,
+    args: RVec<u8>,
+) -> FFIResult<RVec<u8>> {
+    let registry = default_registry();
+    let exprs = rresult_return!(decode_exprs(args.as_slice(), registry));
+
+    // SimplifyInfo is not forwarded across FFI; give the UDF a schema-less
+    // context. UDFs that consult schema/execution-props will not see them.
+    let props = ExecutionProps::new();
+    let info = SimplifyContext::new(&props);
+
+    let result = rresult_return!(udf.inner().simplify(exprs, &info));
+    rresult!(encode_simplify_result(&result).map(RVec::from))
+}
