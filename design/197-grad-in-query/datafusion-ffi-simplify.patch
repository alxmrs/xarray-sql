+    /// A UDF whose `simplify` rewrites `deriv(u)` to `cos(u)`. Both the input
+    /// arg (`sin(x)`) and the output (`cos(...)`) reference built-in functions,
+    /// so resolving them exercises the proto/registry round-trip on both sides.
+    #[derive(Debug, PartialEq, Eq, Hash)]
+    struct DerivUdf {
+        signature: Signature,
+    }
+
+    impl ScalarUDFImpl for DerivUdf {
+        fn as_any(&self) -> &dyn std::any::Any {
+            self
+        }
+        fn name(&self) -> &str {
+            "deriv"
+        }
+        fn signature(&self) -> &Signature {
+            &self.signature
+        }
+        fn return_type(&self, _: &[DataType]) -> Result<DataType> {
+            Ok(DataType::Float64)
+        }
+        fn simplify(
+            &self,
+            args: Vec<Expr>,
+            _info: &dyn SimplifyInfo,
+        ) -> Result<ExprSimplifyResult> {
+            Ok(ExprSimplifyResult::Simplified(
+                datafusion_functions::expr_fn::cos(args[0].clone()),
+            ))
+        }
+        fn invoke_with_args(&self, _: ScalarFunctionArgs) -> Result<ColumnarValue> {
+            internal_err!("deriv marker should have been simplified away")
+        }
+    }
+
+    #[test]
+    fn test_ffi_udf_simplify_forwarding() -> Result<()> {
+        use datafusion_expr::{Volatility, col};
+        use datafusion_functions::expr_fn::{cos, sin};
+
+        let udf = Arc::new(ScalarUDF::from(DerivUdf {
+            signature: Signature::any(1, Volatility::Immutable),
+        }));
+
+        // Force the foreign path so simplify travels through the FFI vtable
+        // rather than the local-bypass shortcut.
+        let mut ffi_udf = FFI_ScalarUDF::from(udf);
+        ffi_udf.library_marker_id = crate::mock_foreign_marker_id;
+        let foreign: Arc<dyn ScalarUDFImpl> = (&ffi_udf).into();
+        assert!(foreign.as_any().downcast_ref::<ForeignScalarUDF>().is_some());
+
+        let props = ExecutionProps::new();
+        let info = SimplifyContext::new(&props);
+        let result = foreign.simplify(vec![sin(col("x"))], &info)?;
+
+        match result {
+            ExprSimplifyResult::Simplified(expr) => {
+                assert_eq!(expr, cos(sin(col("x"))));
+            }
+            ExprSimplifyResult::Original(_) => {
+                panic!("expected the foreign UDF's simplify to fire across FFI")
+            }
+        }
+        Ok(())
+    }
