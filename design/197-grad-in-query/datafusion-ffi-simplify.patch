+    fn simplify(
+        &self,
+        args: Vec<Expr>,
+        _info: &dyn SimplifyInfo,
+    ) -> Result<ExprSimplifyResult> {
+        let encoded = encode_exprs(&args)?;
+        let result = unsafe { (self.udf.simplify)(&self.udf, encoded.into()) };
+        let result_bytes = df_result!(result)?;
+
+        // Tag byte: 1 => Simplified(expr), 0 => Original (keep our own args).
+        match result_bytes.first() {
+            Some(1) => {
+                let expr = Expr::from_bytes_with_registry(
+                    &result_bytes[1..],
+                    default_registry(),
+                )?;
+                Ok(ExprSimplifyResult::Simplified(expr))
+            }
+            _ => Ok(ExprSimplifyResult::Original(args)),
+        }
+    }
 }
 
